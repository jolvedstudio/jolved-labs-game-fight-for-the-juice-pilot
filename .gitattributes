# ===========================================================================
#  Unity .gitattributes  —  line-ending normalization + binary handling
#  Goal: stop spurious "modified" churn (CRLF<->LF) and keep binaries safe.
# ===========================================================================

# Default: let git decide, but always check out/in text files as LF.
* text=auto eol=lf

# ---------------------------------------------------------------------------
#  Unity text/YAML assets — treat as text, normalized to LF.
#  (No merge=union; Unity YAML doesn't merge line-wise safely.)
# ---------------------------------------------------------------------------
*.cs        text diff=csharp eol=lf
*.cginc     text eol=lf
*.shader    text eol=lf
*.uss       text eol=lf
*.uxml      text eol=lf
*.json      text eol=lf
*.txt       text eol=lf
*.md        text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Unity serialized assets (YAML) — text, LF, never auto-merged.
*.meta           text eol=lf merge=binary
*.unity          text eol=lf merge=binary
*.asset          text eol=lf merge=binary
*.prefab         text eol=lf merge=binary
*.mat            text eol=lf merge=binary
*.anim           text eol=lf merge=binary
*.controller     text eol=lf merge=binary
*.overrideController text eol=lf merge=binary
*.physicMaterial text eol=lf merge=binary
*.physicsMaterial2D text eol=lf merge=binary
*.playable       text eol=lf merge=binary
*.mask           text eol=lf merge=binary
*.brush          text eol=lf merge=binary
*.flare          text eol=lf merge=binary
*.fontsettings   text eol=lf merge=binary
*.guiskin        text eol=lf merge=binary
*.giparams       text eol=lf merge=binary
*.renderTexture  text eol=lf merge=binary
*.spriteatlas    text eol=lf merge=binary
*.terrainlayer   text eol=lf merge=binary
*.mixer          text eol=lf merge=binary
*.preset         text eol=lf merge=binary
*.asmdef         text eol=lf
*.asmref         text eol=lf

# ---------------------------------------------------------------------------
#  Binary assets — never touched by line-ending conversion or diff/merge.
# ---------------------------------------------------------------------------
# Images
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.bmp   binary
*.tga   binary
*.tif   binary
*.tiff  binary
*.psd   binary
*.exr   binary
*.hdr   binary
*.ico   binary

# Audio
*.wav   binary
*.mp3   binary
*.ogg   binary
*.aif   binary
*.aiff  binary
*.flac  binary

# Video
*.mp4   binary
*.mov   binary
*.webm  binary

# 3D models
*.fbx   binary
*.obj   binary
*.blend binary
*.dae   binary
*.3ds   binary

# Fonts
*.ttf   binary
*.otf   binary

# Misc
*.dll   binary
*.so    binary
*.dylib binary
*.pdf   binary
*.zip   binary
*.unitypackage binary
